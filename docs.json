      "og:title": "Trusset Protocol - Infrastructure for Asset Tokenization",
      "og:type": "website",
      "og:url": "https://docs.trusset.org",
      "og:image": "https://docs.trusset.org/assets/logo.png",
      "og:description": "End-to-end infrastructure for tokenizing any asset. Build DeFi applications, manage tokenized assets, and access collateralized lending on our blockchain platform.",
